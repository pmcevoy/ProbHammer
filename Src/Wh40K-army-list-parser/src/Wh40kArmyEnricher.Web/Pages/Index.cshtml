@page
@model IndexModel
@{
    ViewData["Title"] = "Upload Army Lists";
}

<div id="loading-overlay">
    <div class="spinner-border text-light mb-3" style="width:3rem;height:3rem;"></div>
    <div>Enriching army lists — this may take a moment...</div>
</div>

<div class="row justify-content-center mt-2">
    <div class="col-12 col-xl-10">
        <h4 class="mb-3 text-light fw-bold">New Matchup</h4>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
        }

        <form method="post" id="upload-form">
            <div class="row g-3">
                <div class="col-md-6">
                    <div class="upload-card h-100">
                        <div class="army-header attacker mb-2">Attacker Army</div>
                        <textarea name="AttackerText" class="army-textarea"
                                  placeholder="Paste attacker army list here..."
                                  autocorrect="off" autocapitalize="none" spellcheck="false" autocomplete="off">@Model.AttackerText</textarea>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="upload-card h-100">
                        <div class="army-header defender mb-2">Defender Army</div>
                        <textarea name="DefenderText" class="army-textarea"
                                  placeholder="Paste defender army list here..."
                                  autocorrect="off" autocapitalize="none" spellcheck="false" autocomplete="off">@Model.DefenderText</textarea>
                    </div>
                </div>
            </div>

            <div class="mt-3 d-flex gap-2">
                <button type="submit" class="btn btn-danger px-4">Enrich &amp; Compare</button>
                <span class="text-muted small align-self-center">
                    Army lists will be enriched against the BSData catalogue.
                </span>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    document.getElementById('upload-form').addEventListener('submit', function () {
        document.getElementById('loading-overlay').classList.add('active');
    });
</script>
}
