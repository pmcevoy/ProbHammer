@model Wh40kArmyEnricher.Contracts.UnitProfile
@{
    var safeName = new string(Model.Name.ToLower().Select(c => char.IsLetterOrDigit(c) ? c : '-').ToArray());
    string cardId = $"unit-{safeName}-{Model.ArmyListIndex}";
    string collapseId = $"collapse-{cardId}";
    string invulnText = Model.InvulnerableSave.HasValue ? $"{Model.InvulnerableSave}++" : "-";
    string fnpText = Model.FeelNoPain.HasValue ? $"{Model.FeelNoPain}+++" : "-";
}

<div class="unit-card-header" data-bs-toggle="collapse" data-bs-target="#@collapseId">
    <div>
        <span class="unit-name">@Model.Name</span>
        <span class="ms-2 small" style="color:#9aa8c0;">(@Model.ModelCount models)</span>
    </div>
    <span class="unit-stats-inline">
        T@(Model.Toughness) Sv@(Model.Save)+ W@(Model.Wounds)
        @if (Model.InvulnerableSave.HasValue) { <span>/@(Model.InvulnerableSave)++</span> }
    </span>
</div>

<div class="collapse" id="@collapseId">
    <div class="unit-card-body">
        <!-- Statline -->
        <table class="statline-table mb-2">
            <thead>
                <tr>
                    <th>T</th><th>Sv</th><th>W</th><th>Inv</th><th>FNP</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>@Model.Toughness</td>
                    <td>@Model.Save+</td>
                    <td>@Model.Wounds</td>
                    <td>@invulnText</td>
                    <td>@fnpText</td>
                </tr>
            </tbody>
        </table>

        <!-- Models & weapons -->
        @foreach (var modelProfile in Model.Models)
        {
            <div class="mb-1 small fw-semibold text-light">
                @modelProfile.ModelName
                @if (modelProfile.Count > 1) { <span style="color:#9aa8c0;">×@modelProfile.Count</span> }
            </div>
            @foreach (var weapon in modelProfile.Weapons)
            {
                <div class="mb-1">
                    <span class="small" style="color:#a8dadc;">@weapon.WeaponName</span>
                    @if (weapon.ModelCount > 1) { <span class="small ms-1" style="color:#9aa8c0;">×@weapon.ModelCount</span> }
                    <span class="badge bg-secondary ms-1" style="font-size:0.6rem;">@weapon.Type</span>
                    @if (weapon.Range > 0) { <span class="text-muted small ms-1">@(weapon.Range)"</span> }
                    <table class="weapon-table mt-1">
                        <thead>
                            <tr>
                                <th>Profile</th><th>A</th><th>Sk</th><th>S</th><th>AP</th><th>D</th><th>Abilities</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var variant in weapon.Profiles)
                            {
                                var abilityList = BuildAbilityList(variant.Abilities);
                                <tr class="weapon-variant-row"
                                    data-weapon-name="@weapon.WeaponName"
                                    data-variant="@variant.Variant"
                                    data-model-name="@modelProfile.ModelName"
                                    data-model-count="@weapon.ModelCount"
                                    data-weapon-type="@weapon.Type">
                                    <td>@variant.Variant</td>
                                    <td>@variant.Attacks</td>
                                    <td>@variant.Skill+</td>
                                    <td>@variant.Strength</td>
                                    <td>@variant.Ap</td>
                                    <td>@variant.Damage</td>
                                    <td style="font-size:0.65rem;text-align:left;">@abilityList</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        }

        <!-- Keywords -->
        @if (Model.Keywords.Count > 0)
        {
            <div class="mt-1">
                @foreach (var kw in Model.Keywords)
                {
                    <span class="keyword-pill">@kw</span>
                }
            </div>
        }

        <!-- Enhancements -->
        @if (Model.Enhancements.Count > 0)
        {
            <div class="mt-1 small" style="color:#c77dff;">
                Enhancements: @string.Join(", ", Model.Enhancements)
            </div>
        }

        <!-- Abilities -->
        @if (Model.Abilities.Count > 0)
        {
            <div class="abilities-section mt-2">
                <div class="abilities-label">Abilities</div>
                @for (int ai = 0; ai < Model.Abilities.Count; ai++)
                {
                    var ability = Model.Abilities[ai];
                    string abilityCollapseId = $"{collapseId}-ability-{ai}";
                    <div class="ability-item">
                        <div class="ability-item-header"
                             data-bs-toggle="collapse"
                             data-bs-target="#@abilityCollapseId"
                             aria-expanded="false"
                             aria-controls="@abilityCollapseId">
                            <span class="ability-item-name">@ability.Name</span>
                            <span class="ability-item-chevron">›</span>
                        </div>
                        <div class="collapse" id="@abilityCollapseId">
                            <div class="ability-item-body">@ability.Text</div>
                            @if (ability.SubAbilities.Count > 0)
                            {
                                <div class="ability-sub-list">
                                    @foreach (var sub in ability.SubAbilities)
                                    {
                                        <div class="ability-sub-item">
                                            <div class="ability-sub-name">@sub.Name</div>
                                            <div class="ability-sub-text">@sub.Text</div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

@functions {
    string BuildAbilityList(Wh40kArmyEnricher.Contracts.WeaponAbilities a)
    {
        var parts = new List<string>();
        if (a.Torrent) parts.Add("Torrent");
        if (a.Blast) parts.Add("Blast");
        if (a.Melta > 0) parts.Add($"Melta {a.Melta}");
        if (a.RapidFire > 0) parts.Add($"RF {a.RapidFire}");
        if (a.SustainedHits > 0) parts.Add($"Sus {a.SustainedHits}");
        if (a.LethalHits) parts.Add("Lethal");
        if (a.DevastatingWounds) parts.Add("Dev.W");
        if (a.TwinLinked) parts.Add("Twin");
        foreach (var (kw, threshold) in a.Anti)
            parts.Add($"Anti-{kw} {threshold}+");
        return string.Join(", ", parts);
    }
}
