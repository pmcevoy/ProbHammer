@page
@using System.Text.Json
@using Wh40kArmyEnricher.Web.Helpers
@model ArmyViewModel
@{
    ViewData["Title"] = "Army View";
}

<main class="army-view">
    @if (Model.CatalogueVersions.Any())
    {
        <div class="catalogue-bar">
            <div class="catalogue-versions">
                @foreach (var cat in Model.CatalogueVersions)
                {
                    <span class="catalogue-badge">@cat.Name <small>rev @cat.Revision</small></span>
                }
            </div>
            <button class="btn-refresh" onclick="refreshCatalogues(this)">Re-download catalogues</button>
        </div>
    }

    <div class="army-columns">
        <div class="army-column">
            <h2>Attacker</h2>
            @for (int i = 0; i < Model.Attackers.Count; i++)
            {
                var unit = Model.Attackers[i];
                var camelCaseJson = JsonSerializer.Serialize(unit, SessionJson.CamelCaseOptions);
                <partial name="_UnitCard" model="@unit" view-data='@(new ViewDataDictionary(ViewData) { ["Side"] = "attacker", ["Index"] = i, ["UnitJson"] = camelCaseJson })'/>
            }
        </div>
        <div class="army-column">
            <h2>Defender</h2>
            @for (int i = 0; i < Model.Defenders.Count; i++)
            {
                var unit = Model.Defenders[i];
                var camelCaseJson = JsonSerializer.Serialize(unit, SessionJson.CamelCaseOptions);
                <partial name="_UnitCard" model="@unit" view-data='@(new ViewDataDictionary(ViewData) { ["Side"] = "defender", ["Index"] = i, ["UnitJson"] = camelCaseJson })'/>
            }
        </div>
    </div>

    <div id="combat-panel" class="combat-panel" style="display:none">
        <!-- Combat panel — populated by JavaScript in Session 6 -->
    </div>
</main>

@section Scripts {
<script>
function refreshCatalogues(btn) {
    btn.disabled = true;
    btn.textContent = 'Refreshing...';
    fetch('/api/refresh-catalogues', { method: 'POST' })
        .then(r => r.json())
        .then(() => { btn.textContent = 'Done — reload to use updated data'; })
        .catch(() => { btn.textContent = 'Refresh failed'; btn.disabled = false; });
}
</script>
}
