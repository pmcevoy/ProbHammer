@page
@model ArmyViewModel
@{
    ViewData["Title"] = "Army View";
    string attackerName = Model.AttackerArmy.FirstOrDefault()?.Faction ?? "Attacker";
    string defenderName = Model.DefenderArmy.FirstOrDefault()?.Faction ?? "Defender";
    var camelCaseJson = new System.Text.Json.JsonSerializerOptions
    {
        PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase
    };
}

@* Inline helper to render a unit card *@
@functions {
    string FormatStat(int val, string suffix = "") => val == 0 ? "-" : $"{val}{suffix}";
    string FormatSave(int val) => val == 0 ? "-" : $"{val}+";
    string FormatOptional(int? val, string suffix = "+") => val.HasValue ? $"{val}{suffix}" : "-";
}

<div id="loading-overlay">
    <div class="spinner-border text-light mb-3" style="width:2rem;height:2rem;"></div>
    <div>Running simulation...</div>
</div>

<div class="row g-2 mb-3">
    <!-- Attacker column -->
    <div class="col-md-6">
        <div class="army-header attacker">⚔ @attackerName — Attacker</div>
        @for (int i = 0; i < Model.AttackerArmy.Count; i++)
        {
            var unit = Model.AttackerArmy[i];
            <div class="unit-card" data-role="attacker" data-index="@i" data-unit='@System.Text.Json.JsonSerializer.Serialize(unit, camelCaseJson)'>
                @await Html.PartialAsync("_UnitCard", unit)
            </div>
        }
    </div>

    <!-- Defender column -->
    <div class="col-md-6">
        <div class="army-header defender">🛡 @defenderName — Defender</div>
        @for (int i = 0; i < Model.DefenderArmy.Count; i++)
        {
            var unit = Model.DefenderArmy[i];
            <div class="unit-card" data-role="defender" data-index="@i" data-unit='@System.Text.Json.JsonSerializer.Serialize(unit, camelCaseJson)'>
                @await Html.PartialAsync("_UnitCard", unit)
            </div>
        }
    </div>
</div>

<!-- Combat panel — shown when attacker(s) and defender are selected -->
<div id="combat-panel" class="mb-3" style="display:none;">
    <div class="combat-panel-title">⚡ Combat Setup</div>

    <div class="row g-2 mb-2">
        <div class="col-12 text-muted small" id="selection-summary">No units selected.</div>
    </div>

    <div class="row g-2">
        <!-- Weapon display (selected by clicking a weapon row in the unit card) -->
        <div class="col-md-7">
            <label class="form-label small text-muted mb-1">Selected Weapon</label>
            <div id="weapon-display" class="weapon-display-hint">
                Expand an attacker unit and click a weapon row to select it.
            </div>
        </div>
        <div class="col-md-2" id="attacking-models-col">
            <label class="form-label small text-muted mb-1">Models firing</label>
            <input type="number" id="attacking-models" class="form-control form-control-sm bg-dark text-light border-secondary" min="1" value="1" />
        </div>
    </div>

    <div class="row g-3 mt-1">
        <!-- Hit rerolls -->
        <div class="col-auto">
            <div class="small text-muted mb-1">Hit Rerolls</div>
            <div class="btn-group btn-group-sm" role="group">
                <input type="radio" class="btn-check" name="hit-rerolls" id="hr-none" value="none" checked />
                <label class="btn btn-outline-secondary" for="hr-none">None</label>
                <input type="radio" class="btn-check" name="hit-rerolls" id="hr-ones" value="ones" />
                <label class="btn btn-outline-secondary" for="hr-ones">Reroll 1s</label>
                <input type="radio" class="btn-check" name="hit-rerolls" id="hr-all" value="all" />
                <label class="btn btn-outline-secondary" for="hr-all">Reroll All</label>
            </div>
        </div>
        <!-- Wound rerolls -->
        <div class="col-auto">
            <div class="small text-muted mb-1">Wound Rerolls</div>
            <div class="btn-group btn-group-sm" role="group">
                <input type="radio" class="btn-check" name="wound-rerolls" id="wr-none" value="none" checked />
                <label class="btn btn-outline-secondary" for="wr-none">None</label>
                <input type="radio" class="btn-check" name="wound-rerolls" id="wr-ones" value="ones" />
                <label class="btn btn-outline-secondary" for="wr-ones">Reroll 1s</label>
                <input type="radio" class="btn-check" name="wound-rerolls" id="wr-all" value="all" />
                <label class="btn btn-outline-secondary" for="wr-all">Reroll All</label>
            </div>
        </div>
        <!-- Toggles -->
        <div class="col-auto d-flex gap-3 align-items-end">
            <div class="form-check form-switch mb-0">
                <input class="form-check-input" type="checkbox" id="within-half-range" />
                <label class="form-check-label small text-muted" for="within-half-range">Half Range</label>
            </div>
            <div class="form-check form-switch mb-0">
                <input class="form-check-input" type="checkbox" id="in-cover" />
                <label class="form-check-label small text-muted" for="in-cover">Cover (+1 Sv)</label>
            </div>
            <div class="form-check form-switch mb-0">
                <input class="form-check-input" type="checkbox" id="crit-5" />
                <label class="form-check-label small text-muted" for="crit-5">Crit on 5+</label>
            </div>
            <div class="form-check form-switch mb-0">
                <input class="form-check-input" type="checkbox" id="plus-one-wound" />
                <label class="form-check-label small text-muted" for="plus-one-wound">+1 to Wound</label>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <button id="run-sim-btn" class="btn btn-danger px-4" disabled>Run Simulation</button>
    </div>

    <!-- Results -->
    <div id="results-panel" style="display:none;">
        <div class="small text-muted mb-2" id="results-description"></div>
        <div class="row text-center g-3">
            <div class="col-6 col-md-3">
                <div class="result-value" id="res-mean">—</div>
                <div class="result-label">Mean Damage</div>
            </div>
            <div class="col-6 col-md-3">
                <div class="result-value" id="res-kills">—</div>
                <div class="result-label">Expected Kills</div>
            </div>
            <div class="col-6 col-md-3">
                <div class="result-value" id="res-prob-kill">—</div>
                <div class="result-label">P(Kill ≥ 1)</div>
            </div>
            <div class="col-6 col-md-3">
                <div class="result-value" id="res-std">—</div>
                <div class="result-label">Std Deviation</div>
            </div>
        </div>
        <div class="mt-2 small text-muted" id="res-range"></div>

        <!-- Attack pipeline funnel — content generated by army-view.js -->
        <div class="pipeline-section mt-3" id="pipeline-section" style="display:none;">
            <div class="pipeline-title">Attack Pipeline</div>
            <div id="pipeline-content"></div>
        </div>
    </div>
</div>

@section Scripts {
<script src="~/js/army-view.js"></script>
}
